# Raftra Backend Environment Variables - PRODUCTION

# 1. Database & Cache
# Supabase PostgreSQL URL (ensure connection pooling port is used for prod, typically 6543)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
# Upstash Redis URL (use rediss:// for TLS)
REDIS_URL=rediss://default:password@xxxx.upstash.io:6379

# 2. Supabase Settings (Storage & Auth)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key
SUPABASE_BUCKET=raftra-media

# 3. Authentication & Security
# Note: if using Clerk for auth, CLERK_SECRET_KEY is needed
CLERK_ISSUER_URL=https://clerk.yourdomain.com
CLERK_SECRET_KEY=sk_test_...
JWT_SECRET=super_secret_jwt_key_here
FRONTEND_URL=https://app.raftra.com

# 4. Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=secret_...
RAZORPAY_WEBHOOK_SECRET=webhook_secret_here

# 5. Integrations & Data Sources
COMPOSIO_API_KEY=your_composio_api_key
FIRECRAWL_API_KEY=fc-...
TAVILY_API_KEY=your_tavily_key_here

# 6. LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-v1-...

# 7. Media Generation APIs
FLUX_API_KEY=your_flux_key_here
IDEOGRAM_API_KEY=your_ideogram_key_here
RECRAFT_API_KEY=your_recraft_key_here
SEEDANCE_API_KEY=your_seedance_key_here
KLING_API_KEY=your_kling_key_here
KOKORO_API_KEY=your_kokoro_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here
