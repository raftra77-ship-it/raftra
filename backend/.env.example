# Raftra Backend Environment Variables

# 1. Database & Cache
DATABASE_URL=postgresql://user:password@127.0.0.1:5444/raftra_db
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# 2. Scraping & Intelligence (Brand Onboarding)
FIRECRAWL_API_KEY=fc-5042e46eb73c4d4dafc742e0ff590c8c
TAVILY_API_KEY=your_tavily_key_here

# 3. LLM Providers (Text, Strategy, Routing)
# Place your key for the provider you want to use
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-v1-...

# 4. Image Generation Providers
# Note: DALL-E 3 / GPT Image uses the OPENAI_API_KEY from section 3 above.
FLUX_API_KEY=your_flux_key_here
IDEOGRAM_API_KEY=your_ideogram_key_here
RECRAFT_API_KEY=your_recraft_key_here

# 5. Video & Audio Providers
SEEDANCE_API_KEY=your_seedance_key_here
KLING_API_KEY=your_kling_key_here
KOKORO_API_KEY=your_kokoro_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here
